<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- CRON 1: Actualización diaria de estado de pedidos -->
        <record id="cron_update_request_states" model="ir.cron">
            <field name="name">Marketplace: Actualizar estados de solicitudes (Diario)</field>
            <field name="model_id" ref="model_construction_material_request"/>
            <field name="state">code</field>
            <field name="code">model._cron_update_request_states()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="priority">5</field>
        </record>

        <!-- CRON 2: Alertas de solicitudes sin respuesta en más de 48h -->
        <record id="cron_alert_pending_requests" model="ir.cron">
            <field name="name">Marketplace: Alertas solicitudes pendientes 48h</field>
            <field name="model_id" ref="model_construction_material_request"/>
            <field name="state">code</field>
            <field name="code">model._cron_alert_pending_requests()</field>
            <field name="interval_number">4</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="priority">5</field>
        </record>

        <!-- CRON 3: Reporte semanal de materiales más solicitados -->
        <record id="cron_weekly_report" model="ir.cron">
            <field name="name">Marketplace: Reporte semanal de materiales</field>
            <field name="model_id" ref="model_construction_material_request"/>
            <field name="state">code</field>
            <field name="code">model._cron_weekly_material_report()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="priority">10</field>
        </record>

    </data>
</odoo>
