<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         VISTAS DE SOLICITUD DE MATERIALES
         ============================================================ -->

    <!-- Vista formulario de Solicitud de Materiales -->
    <record id="view_construction_material_request_form" model="ir.ui.view">
        <field name="name">construction.material.request.form</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <form string="Solicitud de Materiales">
                <header>
                    <!-- Botones de flujo de estado -->
                    <button name="action_confirm"
                            string="✔ Confirmar / Tramitar"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="¿Confirmar esta solicitud de materiales?"/>
                    <button name="action_set_en_preparacion"
                            string="📦 En Preparación"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_set_en_reparto"
                            string="🚚 En Reparto"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'en_preparacion'"/>
                    <button name="action_set_delivered"
                            string="✅ Marcar como Entregado"
                            type="object"
                            class="btn-success"
                            invisible="state not in ['en_reparto', 'in_progress']"
                            confirm="¿Confirmar la entrega de los materiales al cliente?"/>
                    <button name="action_convert_to_sale"
                            string="Convertir a Pedido de Venta"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ['confirmed', 'en_preparacion', 'en_reparto', 'in_progress'] or sale_order_id != False"/>
                    <button name="action_cancel"
                            string="Cancelar"
                            type="object"
                            invisible="state in ['draft', 'delivered', 'cancelled']"
                            confirm="¿Cancelar esta solicitud de materiales?"/>
                    <button name="action_reset_draft"
                            string="Volver a Borrador"
                            type="object"
                            invisible="state not in ['confirmed', 'en_preparacion', 'cancelled']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,en_preparacion,en_reparto,delivered"/>
                </header>

                <sheet>
                    <!-- Botón de pedido de venta vinculado -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_order"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                invisible="not sale_order_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Pedido de Venta</span>
                                <span class="o_stat_value">
                                    <field name="sale_order_id"/>
                                </span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Información de la Solicitud">
                            <field name="obra_id"
                                   options="{'no_create': True, 'no_quick_create': True}"
                                   readonly="state in ['delivered', 'cancelled']"/>
                            <field name="partner_id"
                                   options="{'no_create': True}"/>
                            <field name="user_id"
                                   options="{'no_create': True}"/>
                            <field name="date_request"/>
                            <field name="date_required"/>
                        </group>
                        <group string="Importes">
                            <field name="is_urgent" string="⚡ Pedido Urgente (+50% transporte)"/>
                            <field name="total_amount"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1"
                                   string="Importe Total"/>
                            <field name="transport_cost"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1"
                                   string="Coste de Transporte (€)"/>
                            <field name="total_with_transport"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1"
                                   string="Total con Transporte (€)"/>
                        </group>
                    </group>

                    <!-- Lineas de materiales -->
                    <notebook>
                        <page string="Materiales Solicitados" name="lines">
                            <field name="line_ids"
                                   readonly="state not in ['draft']">
                                <tree string="Líneas de Materiales"
                                      editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"
                                           required="1"
                                           domain="[('sale_ok', '=', True)]"/>
                                    <field name="product_name"/>
                                    <field name="product_qty" required="1"/>
                                    <field name="product_uom_id"
                                           options="{'no_open': True, 'no_create': True}"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="notes"/>
                                </tree>
                            </field>

                            <!-- Total al pie de las lineas -->
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_amount"
                                       string="Total Solicitud"
                                       readonly="1"/>
                            </group>
                        </page>

                        <page string="Notas e Información" name="notes_tracking">
                            <group>
                                <field name="notes"
                                       placeholder="Observaciones, requisitos especiales, urgencia..."/>
                            </group>
                            <group string="Historial de Seguimiento">
                                <field name="tracking_info"
                                       nolabel="1"
                                       readonly="1"
                                       placeholder="El historial de seguimiento aparecerá aquí automáticamente..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista lista (tree) de Solicitud de Materiales -->
    <record id="view_construction_material_request_list" model="ir.ui.view">
        <field name="name">construction.material.request.list</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <tree string="Solicitudes de Materiales"
                  decoration-success="state == 'delivered'"
                  decoration-info="state in ['en_reparto', 'in_progress'] and not is_urgent"
                  decoration-warning="state in ['confirmed', 'en_preparacion'] and not is_urgent"
                  decoration-danger="state == 'cancelled' or (is_urgent and state not in ['delivered', 'cancelled'])"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="is_urgent" widget="boolean" string="⚡ Urgente" optional="show"/>
                <field name="obra_id"/>
                <field name="delivery_address" optional="show"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="date_request"/>
                <field name="date_required"/>
                <field name="total_amount" sum="Total"/>
                <field name="transport_cost" sum="Transporte" optional="show"/>
                <field name="sale_order_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'delivered'"
                       decoration-info="state in ['en_reparto', 'in_progress']"
                       decoration-warning="state in ['confirmed', 'en_preparacion']"
                       decoration-danger="state == 'cancelled'"
                       decoration-muted="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- Vista búsqueda de Solicitud de Materiales -->
    <record id="view_construction_material_request_search" model="ir.ui.view">
        <field name="name">construction.material.request.search</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <search string="Buscar Solicitudes">
                <field name="name" string="Referencia"/>
                <field name="obra_id" string="Obra"/>
                <field name="partner_id" string="Empresa/Cliente"/>
                <field name="user_id" string="Solicitante"/>
                <separator/>
                <filter name="filter_draft" string="Borrador"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Tramitando"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_en_preparacion" string="En Preparación"
                        domain="[('state', '=', 'en_preparacion')]"/>
                <filter name="filter_en_reparto" string="En Reparto"
                        domain="[('state', 'in', ['en_reparto', 'in_progress'])]"/>
                <filter name="filter_delivered" string="Entregados"
                        domain="[('state', '=', 'delivered')]"/>
                <filter name="filter_cancelled" string="Canceladas"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="filter_my_requests" string="Mis Solicitudes"
                        domain="[('user_id', '=', uid)]"/>
                <filter name="filter_no_sale" string="Sin Pedido de Venta"
                        domain="[('sale_order_id', '=', False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_obra" string="Obra"
                            context="{'group_by': 'obra_id'}"/>
                    <filter name="group_partner" string="Empresa/Cliente"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_user" string="Solicitante"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_date" string="Fecha de Solicitud"
                            context="{'group_by': 'date_request:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción de ventana para Solicitudes de Materiales -->
    <record id="action_construction_material_request" model="ir.actions.act_window">
        <field name="name">Solicitudes de Materiales</field>
        <field name="res_model">construction.material.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_construction_material_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear primera solicitud de materiales
            </p>
            <p>
                Gestiona las solicitudes de materiales para tus obras
                y conviértelas en pedidos de venta de forma automática.
            </p>
        </field>
    </record>

    <!-- Vista Kanban de Solicitudes de Materiales -->
    <record id="view_construction_material_request_kanban" model="ir.ui.view">
        <field name="name">construction.material.request.kanban</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" group_create="false" group_delete="false">
                <field name="state"/>
                <field name="name"/>
                <field name="obra_id"/>
                <field name="partner_id"/>
                <field name="total_amount"/>
                <field name="date_required"/>
                <field name="delivery_address"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <t t-if="record.obra_id.value">
                                        <div><span class="text-muted">Obra: </span><t t-esc="record.obra_id.value"/></div>
                                    </t>
                                    <t t-if="record.partner_id.value">
                                        <div><span class="text-muted">Cliente: </span><t t-esc="record.partner_id.value"/></div>
                                    </t>
                                    <t t-if="record.delivery_address.value">
                                        <div><span class="text-muted">Dir: </span><t t-esc="record.delivery_address.value"/></div>
                                    </t>
                                    <t t-if="record.date_required.value">
                                        <div><span class="text-muted">Entrega: </span><t t-esc="record.date_required.value"/></div>
                                    </t>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <strong><field name="total_amount"/> €</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Acción Pedidos Activos (kanban primero) -->
    <record id="action_construction_pedidos_activos" model="ir.actions.act_window">
        <field name="name">Pedidos Activos</field>
        <field name="res_model">construction.material.request</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('state', 'not in', ['draft', 'cancelled', 'delivered'])]</field>
        <field name="context">{'group_by': 'state'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay pedidos activos</p>
            <p>Los pedidos activos (tramitando, en preparación, en reparto) aparecerán aquí.</p>
        </field>
    </record>

    <!-- Vista lista especial para Inventario de Materiales -->
    <record id="view_product_template_marketplace_list" model="ir.ui.view">
        <field name="name">product.template.marketplace.list</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <tree string="Inventario de Materiales" decoration-danger="qty_marketplace == 0" decoration-success="qty_marketplace > 0">
                <field name="name" string="Producto"/>
                <field name="default_code" string="Ref."/>
                <field name="categ_id" string="Categoría"/>
                <field name="list_price" string="Precio venta" widget="monetary"/>
                <field name="uom_id" string="Unidad" optional="show"/>
                <field name="qty_marketplace" string="Stock disponible"/>
                <field name="description_sale" string="Descripción" optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Vista formulario de producto para el marketplace -->
    <record id="view_product_template_marketplace_form" model="ir.ui.view">
        <field name="name">product.template.marketplace.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <div class="alert alert-info" role="alert" style="margin:8px 16px 0 16px;">
                    <strong>Construction Marketplace</strong> — Rellena Referencia Interna, Precio de Venta y Stock Disponible para que el producto aparezca en el catálogo.
                </div>
            </xpath>
            <xpath expr="//field[@name='description_sale']" position="after">
                <field name="qty_marketplace" string="Stock Disponible (Marketplace)"/>
            </xpath>
        </field>
    </record>

    <!-- Acción Inventario de Materiales -->
    <record id="action_construction_inventario_materiales" model="ir.actions.act_window">
        <field name="name">Inventario de Materiales</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5,0,0),(0,0,{'view_mode':'tree','view_id':ref('view_product_template_marketplace_list')})]"/>
        <field name="domain">[('sale_ok', '=', True), ('default_code', '!=', False), ('default_code', 'not ilike', 'FURN'), ('default_code', 'not ilike', 'E-COM')]</field>
        <field name="context">{'default_sale_ok': True, 'default_type': 'consu'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Sin productos en el catálogo</p>
            <p>Haz clic en <b>Nuevo</b> para añadir un producto. Rellena nombre, referencia, precio y stock disponible.</p>
        </field>
    </record>

    <!-- Acción Clientes -->
    <record id="action_construction_clientes" model="ir.actions.act_window">
        <field name="name">Clientes</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('customer_rank', '>', 0)]</field>
        <field name="context">{'search_default_customer': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Sin clientes todavía</p>
            <p>Los clientes registrados desde el portal aparecerán aquí.</p>
        </field>
    </record>

</odoo>
