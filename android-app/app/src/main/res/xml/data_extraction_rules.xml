<?xml version="1.0" encoding="utf-8"?>
<!--
    Reglas de extracción de datos para Android 12+.
    Excluimos las preferencias cifradas de sesión del cloud backup
    y de las transferencias de dispositivo a dispositivo.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="sharedpref"
            path="construapp_secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="sharedpref"
            path="construapp_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
