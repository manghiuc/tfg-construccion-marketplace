<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Directorio de caché para fotos tomadas con la cámara -->
    <cache-path
        name="cached_images"
        path="images/" />
