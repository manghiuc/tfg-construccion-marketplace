<?xml version="1.0" encoding="utf-8"?>
<!-- Logo ConstruApp: C bracket blanco sobre fondo naranja (adaptive icon foreground) -->
<!-- Área segura adaptive icon: 72x72dp centrada en 108x108 (margen 18dp cada lado) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      C bracket:
        - Cuerpo izquierdo vertical:  x=25..41, y=22..86  (ancho 16, alto 64)
        - Brazo superior horizontal:  x=25..83, y=22..38  (ancho 58, alto 16)
        - Brazo inferior horizontal:  x=25..83, y=70..86  (ancho 58, alto 16)
      Resultado: C con proporciones equilibradas, serifs marcadas.
    -->

    <!-- Brazo superior -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M25,22 L83,22 Q87,22 87,26 L87,38 Q87,38 83,38 L25,38 Z"/>

    <!-- Cuerpo vertical izquierdo -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M25,22 L41,22 L41,86 L25,86 Z"/>

    <!-- Brazo inferior -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M25,70 L83,70 Q87,70 87,74 L87,86 Q87,86 83,86 L25,86 Z"/>

</vector>
